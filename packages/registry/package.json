{
  "name": "@getmcp/registry",
  "version": "0.10.0",
  "description": "Registry of MCP server definitions synced from the official MCP registry",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "registry",
    "server-directory"
  ],
  "homepage": "https://github.com/RodrigoTomeES/getmcp/tree/main/packages/registry#readme",
  "bugs": {
    "url": "https://github.com/RodrigoTomeES/getmcp/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RodrigoTomeES/getmcp.git",
    "directory": "packages/registry"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "tsx --env-file=.env scripts/sync.ts",
    "sync:full": "tsx --env-file=.env scripts/sync.ts --full",
    "build": "tsc && tsx scripts/copy-data.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@getmcp/core": "*"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
