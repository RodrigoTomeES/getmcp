{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "server": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "websiteUrl": {
          "type": "string"
        },
        "repository": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string"
            },
            "source": {
              "type": "string"
            },
            "id": {
              "type": "string"
            },
            "subfolder": {
              "type": "string"
            }
          },
          "required": ["url", "source"],
          "additionalProperties": false
        },
        "icons": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "src": {
                "type": "string"
              },
              "mimeType": {
                "type": "string"
              },
              "sizes": {
                "anyOf": [
                  {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  {
                    "type": "string"
                  }
                ]
              },
              "theme": {
                "type": "string",
                "enum": ["light", "dark"]
              }
            },
            "required": ["src"],
            "additionalProperties": false
          }
        },
        "packages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "registryType": {
                "type": "string",
                "enum": ["npm", "pypi", "oci", "nuget", "mcpb"]
              },
              "identifier": {
                "type": "string"
              },
              "version": {
                "type": "string"
              },
              "runtimeHint": {
                "type": "string"
              },
              "transport": {
                "type": "object",
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["stdio", "streamable-http", "sse"]
                  },
                  "url": {
                    "type": "string"
                  }
                },
                "required": ["type"],
                "additionalProperties": false
              },
              "packageArguments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "default": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string",
                      "enum": ["string", "number", "boolean", "filepath"]
                    },
                    "isRequired": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "runtimeArguments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "default": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string",
                      "enum": ["string", "number", "boolean", "filepath"]
                    },
                    "isRequired": {
                      "type": "boolean"
                    }
                  },
                  "additionalProperties": false
                }
              },
              "environmentVariables": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "default": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string",
                      "enum": ["string", "number", "boolean", "filepath"]
                    },
                    "isRequired": {
                      "type": "boolean"
                    },
                    "isSecret": {
                      "type": "boolean"
                    }
                  },
                  "required": ["name"],
                  "additionalProperties": false
                }
              }
            },
            "required": ["registryType", "identifier", "transport"],
            "additionalProperties": false
          }
        },
        "remotes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["streamable-http", "sse"]
              },
              "url": {
                "type": "string"
              },
              "headers": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "value": {
                      "type": "string"
                    },
                    "default": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string",
                      "enum": ["string", "number", "boolean", "filepath"]
                    },
                    "isRequired": {
                      "type": "boolean"
                    },
                    "isSecret": {
                      "type": "boolean"
                    }
                  },
                  "required": ["name"],
                  "additionalProperties": false
                }
              },
              "variables": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "type": "string"
                    },
                    "format": {
                      "type": "string"
                    },
                    "default": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "required": ["type", "url"],
            "additionalProperties": false
          }
        },
        "_meta": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "required": ["name", "description"],
      "additionalProperties": false
    },
    "_meta": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": ["server", "_meta"],
  "additionalProperties": false
}
